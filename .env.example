# ========================================
# TELEGRAM
# ========================================
BOT_TOKEN=your-telegram-bot-token
BOT_USERNAME=yourbotusername
ADMIN_TELEGRAM_ID=your-telegram-id
WEBHOOK_URL=https://yourdomain.com/webhook

# ========================================
# BACKEND
# ========================================
SECRET_KEY=your-super-secret-key-change-in-production-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========================================
# DATABASE
# ========================================
POSTGRES_USER=onec_helper
POSTGRES_PASSWORD=onec_helper_pass
POSTGRES_DB=onec_helper_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://onec_helper:onec_helper_pass@postgres:5432/onec_helper_db

# ========================================
# REDIS
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ========================================
# AI
# ========================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ========================================
# MINIAPP
# ========================================
MINIAPP_URL=https://yourdomain.com
BACKEND_URL=http://backend:8000

# ========================================
# ENCRYPTION
# ========================================
ENCRYPTION_KEY=your-32-byte-fernet-encryption-key=

# ========================================
# ENVIRONMENT
# ========================================
ENVIRONMENT=production
LOG_LEVEL=INFO
