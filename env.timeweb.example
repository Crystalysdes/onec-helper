# Copy this to .env on the VPS at /opt/onec-helper/.env
# Replace all values with your real ones

# Database — Timeweb Cloud Managed PostgreSQL connection string
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql+asyncpg://gen_user:PASSWORD@HOST.timeweb.cloud:5432/DATABASE

# Redis — running in Docker on same VPS
REDIS_URL=redis://redis:6379/0

# Telegram Bot
BOT_TOKEN=8241924602:AAHxqUWIR3II3JHliS22TM6kCw-PhKONh8A
BOT_USERNAME=oneshelperbot
ADMIN_TELEGRAM_ID=5504548686

# Backend URL (your domain with https)
BACKEND_URL=https://YOUR_DOMAIN

# Miniapp URL (Netlify)
MINIAPP_URL=https://wondrous-manatee-cfe6f7.netlify.app

# Auth
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Encryption
ENCRYPTION_KEY=your_fernet_key_here

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Optional: AI / payment (leave empty if not used)
ANTHROPIC_API_KEY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
